# Copy this file to .env and set the values for your MySQL server.
# You can also use a single connection string via DATABASE_URL (e.g. mysql://user:pass@host:port/db).
# Example:
# DATABASE_URL=mysql://root:your_password@localhost:3306/shop

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=shop
